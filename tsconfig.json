{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "declaration": true,
    "noEmit": false,
    "outDir": "dist",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
